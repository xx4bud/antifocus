{
  "name": "antifocus",
  "private": true,
  "scripts": {
    "build": "turbo build",
    "dev": "turbo dev",
    "clean": "git clean -xdf node_modules",
    "clean:workspaces": "turbo clean",
    "check:lint": "biome check --write --unsafe .",
    "check:types": "turbo check:types",
    "check:all": "pnpm check:lint && pnpm check:types",
    "check:deps": "sherif --fix",
    "bump:deps": "pnpm dlx npm-check-updates --deep -u -x geist",
    "postinstall": "sherif",
    "gen:schemas": "pnpm --filter @antifocus/cli gen:schemas",
    "gen:schemas:all": "pnpm --filter @antifocus/cli gen:schemas:all",
    "prepare": "husky"
  },
  "devDependencies": {
    "@biomejs/biome": "catalog:",
    "@commitlint/cli": "^20.2.0",
    "@commitlint/config-conventional": "^20.2.0",
    "dotenv-cli": "^11.0.0",
    "husky": "^9.1.7",
    "sherif": "^1.9.0",
    "turbo": "^2.6.3",
    "typescript": "catalog:",
    "ultracite": "6.3.9"
  },
  "commitlint": {
    "extends": [
      "@commitlint/config-conventional"
    ]
  },
  "overrides": {
    "@biomejs/biome": "catalog:"
  },
  "engines": {
    "node": "22.x",
    "pnpm": "10.x"
  },
  "packageManager": "pnpm@10.24.0"
}
