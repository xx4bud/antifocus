{
  "name": "antifocus",
  "type": "module",
  "private": true,
  "scripts": {
    "with:env": "dotenv -e .env --",
    "dev": "pnpm with:env next dev",
    "build": "pnpm with:env next build",
    "start": "pnpm with:env next start",
    "clean": "git clean -xdf .cache .next node_modules",
    "check:lint": "ultracite fix",
    "check:types": "pnpm with:env next typegen && tsc --noEmit",
    "check:all": "pnpm check:lint && pnpm check:types",
    "auth:generate": "dotenv -e .env -- pnpx @better-auth/cli generate --config src/lib/auth/index.ts --output better-auth.ts --yes",
    "db:push": "pnpm with:env drizzle-kit push --config drizzle.config.ts",
    "db:generate": "pnpm with:env drizzle-kit generate --config drizzle.config.ts",
    "db:migrate": "pnpm with:env drizzle-kit migrate --config drizzle.config.ts",
    "db:seed": "pnpm with:env tsx scripts/seed-main.ts",
    "prepare": "husky"
  },
  "dependencies": {
    "@aws-sdk/client-s3": "^3.1023.0",
    "@aws-sdk/s3-request-presigner": "^3.1023.0",
    "@better-auth/api-key": "^1.5.6",
    "@better-auth/expo": "^1.5.6",
    "@neondatabase/serverless": "^1.0.2",
    "@node-rs/argon2": "^2.0.2",
    "@paralleldrive/cuid2": "^3.3.0",
    "@t3-oss/env-nextjs": "^0.13.11",
    "@tabler/icons-react": "^3.41.1",
    "@tanstack/react-form": "^1.28.6",
    "@tanstack/react-query": "^5.96.1",
    "@tanstack/react-table": "^8.21.3",
    "@tiptap/core": "^3.22.1",
    "@tiptap/pm": "^3.22.1",
    "@tiptap/react": "^3.22.1",
    "@trpc/client": "^11.16.0",
    "@trpc/server": "^11.16.0",
    "@trpc/tanstack-react-query": "^11.16.0",
    "@upstash/redis": "^1.37.0",
    "@vercel/analytics": "^2.0.1",
    "@vercel/og": "^0.11.1",
    "@vercel/speed-insights": "^2.0.0",
    "better-auth": "^1.5.6",
    "class-variance-authority": "^0.7.1",
    "client-only": "^0.0.1",
    "clsx": "^2.1.1",
    "cmdk": "^1.1.1",
    "date-fns": "^4.1.0",
    "date-fns-tz": "^3.2.0",
    "dinero.js": "^2.0.2",
    "drizzle-orm": "^0.45.2",
    "fumadocs-mdx": "^14.2.11",
    "fumadocs-ui": "^16.7.10",
    "inngest": "^4.1.1",
    "konva": "^10.2.3",
    "libphonenumber-js": "^1.12.41",
    "midtrans-client": "^1.4.3",
    "next": "16.2.1",
    "next-intl": "^4.8.3",
    "next-sitemap": "^4.2.3",
    "next-themes": "^0.4.6",
    "orama": "^2.0.6",
    "puppeteer": "^24.40.0",
    "radix-ui": "^1.4.3",
    "react": "19.2.4",
    "react-dom": "19.2.4",
    "react-konva": "^19.2.3",
    "recharts": "3.8.0",
    "resend": "^6.10.0",
    "server-only": "^0.0.1",
    "shadcn": "^4.1.1",
    "sharp": "^0.34.5",
    "sonner": "^2.0.7",
    "superjson": "^2.2.6",
    "tailwind-merge": "^3.5.0",
    "tw-animate-css": "^1.4.0",
    "web-push": "^3.6.7",
    "zod": "^4.3.6"
  },
  "devDependencies": {
    "@biomejs/biome": "2.4.9",
    "@commitlint/cli": "^20.5.0",
    "@commitlint/config-conventional": "^20.5.0",
    "@tailwindcss/postcss": "^4.2.0",
    "@tanstack/intent": "^0.0.27",
    "@types/node": "^22.19.0",
    "@types/react": "^19.2.3",
    "@types/react-dom": "^19.2.3",
    "babel-plugin-react-compiler": "1.0.0",
    "dotenv-cli": "^11.0.0",
    "drizzle-kit": "^0.31.10",
    "husky": "^9.1.7",
    "jiti": "^2.6.1",
    "lint-staged": "^16.4.0",
    "tailwindcss": "^4.2.0",
    "tsx": "^4.21.0",
    "typescript": "^5.9.3",
    "ultracite": "7.4.0"
  },
  "commitlint": {
    "extends": [
      "@commitlint/config-conventional"
    ]
  },
  "lint-staged": {
    "*.{js,jsx,ts,tsx,json,jsonc,css,scss,md,mdx}": [
      "pnpm check:lint"
    ]
  },
  "engines": {
    "node": ">=22.x",
    "pnpm": ">=10.x"
  },
  "packageManager": "pnpm@10.33.0"
}
