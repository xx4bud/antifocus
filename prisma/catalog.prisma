// ==============================
// Products
// ==============================

model Product {
    id             String @id @default(cuid())
    organizationId String @map("organization_id")

    name String
    slug String

    status   ProductStatus @default(draft)
    metadata Json?         @db.JsonB

    createdAt DateTime  @default(now()) @map("created_at") @db.Timestamptz(3)
    updatedAt DateTime  @updatedAt @map("updated_at") @db.Timestamptz(3)
    deletedAt DateTime? @map("deleted_at") @db.Timestamptz(3)

    organization Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)

    images      ProductImage[]
    attributes  ProductAttribute[]
    variants    Variant[]
    designAreas DesignArea[]
    tags        ProductTag[]
    categories  ProductCategory[]

    @@unique([organizationId, slug])
    @@map("products")
}

model ProductImage {
    id        String @id @default(cuid())
    productId String @map("product_id")
    fileId    String @map("file_id")

    position  Int      @default(0)
    createdAt DateTime @default(now()) @map("created_at") @db.Timestamptz(3)

    product Product @relation(fields: [productId], references: [id], onDelete: Cascade)
    file    File    @relation(fields: [fileId], references: [id], onDelete: Restrict)

    @@unique([productId, fileId])
    @@map("product_images")
}

model ProductCategory {
    id         String @id @default(cuid())
    productId  String @map("product_id")
    categoryId String @map("category_id")

    position  Int      @default(0)
    createdAt DateTime @default(now()) @map("created_at") @db.Timestamptz(3)

    product  Product  @relation(fields: [productId], references: [id], onDelete: Cascade)
    category Category @relation(fields: [categoryId], references: [id], onDelete: Cascade)

    @@unique([productId, categoryId])
    @@map("product_categories")
}

model ProductAttribute {
    id          String  @id @default(cuid())
    productId   String  @map("product_id")
    attributeId String  @map("attribute_id")
    optionId    String? @map("option_id")

    value Json? @db.JsonB

    createdAt DateTime @default(now()) @map("created_at") @db.Timestamptz(3)

    product   Product          @relation(fields: [productId], references: [id], onDelete: Cascade)
    attribute Attribute        @relation(fields: [attributeId], references: [id], onDelete: Restrict)
    option    AttributeOption? @relation(fields: [optionId], references: [id], onDelete: Restrict)

    @@unique([productId, attributeId])
    @@map("product_attributes")
}

model ProductTag {
    id        String @id @default(cuid())
    productId String @map("product_id")
    tagId     String @map("tag_id")

    createdAt DateTime @default(now()) @map("created_at") @db.Timestamptz(3)

    product Product @relation(fields: [productId], references: [id], onDelete: Cascade)
    tag     Tag     @relation(fields: [tagId], references: [id], onDelete: Cascade)

    @@unique([productId, tagId])
    @@map("product_tags")
}

// ==============================
// Variants
// ==============================

model Variant {
    id        String @id @default(cuid())
    productId String @map("product_id")

    name String
    sku  String

    currencyCode CurrencyCode @default(IDR) @map("currency_code")
    costPrice    BigInt       @map("cost_price")
    basePrice    BigInt       @map("base_price")
    salePrice    BigInt       @map("sale_price")

    enabled  Boolean @default(false)
    metadata Json?   @db.JsonB

    createdAt DateTime  @default(now()) @map("created_at") @db.Timestamptz(3)
    updatedAt DateTime  @updatedAt @map("updated_at") @db.Timestamptz(3)
    deletedAt DateTime? @map("deleted_at") @db.Timestamptz(3)

    product Product @relation(fields: [productId], references: [id], onDelete: Cascade)

    options              VariantOption[]
    images               VariantImage[]
    mockups              DesignMockup[]
    orders               OrderItem[]
    purchaseOrderItems   PurchaseOrderItem[]
    productionOrderItems ProductionOrderItem[]
    branchStocks         BranchStock[]

    @@unique([productId, sku])
    @@index([productId])
    @@map("variants")
}

model VariantImage {
    id        String @id @default(cuid())
    variantId String @map("variant_id")
    fileId    String @map("file_id")

    position  Int      @default(0)
    createdAt DateTime @default(now()) @map("created_at") @db.Timestamptz(3)

    variant Variant @relation(fields: [variantId], references: [id], onDelete: Cascade)
    file    File    @relation(fields: [fileId], references: [id], onDelete: Restrict)

    @@unique([variantId, fileId])
    @@map("variant_images")
}

model VariantOption {
    id        String @id @default(cuid())
    variantId String @map("variant_id")
    optionId  String @map("option_id")

    position  Int      @default(0)
    createdAt DateTime @default(now()) @map("created_at") @db.Timestamptz(3)

    variant Variant         @relation(fields: [variantId], references: [id], onDelete: Cascade)
    option  AttributeOption @relation(fields: [optionId], references: [id], onDelete: Restrict)

    @@unique([variantId, optionId])
    @@map("variant_options")
}
