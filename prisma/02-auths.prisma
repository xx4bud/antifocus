// ==============================
// AUTH ENUMS
// ==============================

enum SystemUserRole {
  user
  admin
}

enum UserStatus {
  pending // not verified
  active // verified
  inactive // by user
  deleted
}

enum ActionType {
  create
  update
  delete
  view
  export
  import
  login
  logout
  forgot_password
  reset_password
  approve
  reject
  cancel
  complete
}

enum ActorType {
  system
  api_keys
  webhooks
  user
}

// ==============================
// BETTER-AUTH USERS
// ==============================

model User {
  id            String  @id @default(cuid())
  name          String
  email         String  @unique
  emailVerified Boolean @default(false)
  image         String? // avatar

  // username plugin
  username        String? @unique
  displayUsername String?

  // phone number plugin
  phoneNumber         String?
  phoneNumberVerified Boolean @default(false)

  // admin plugin
  role       String    @default("user")
  banned     Boolean   @default(false)
  banReason  String?
  banExpires DateTime?

  // 2fa plugin
  twoFactorEnable Boolean @default(false)

  // additionals
  banner   String?
  status   UserStatus @default(pending)
  settings Json? // preferences
  metadata Json?

  // timestamps
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  // soft delete
  deletedAt DateTime?

  sessions     Session[]
  accounts     Account[]
  twoFactors   TwoFactor[]
  apiKeys      ApiKey[]
  activityLogs ActivityLog[]
  members      Member[]
  invitations  Invitation[]
  customers    Customer[]
  profiles     Profile[]

  @@index([role])
  @@index([status, banned])
  @@map("users")
}

// ==============================
// BETTER-AUTH SESSIONS
// ==============================

model Session {
  id        String   @id @default(cuid())
  token     String   @unique
  expiresAt DateTime

  // context
  userId    String
  ipAddress String?
  userAgent String?

  // admin plugin
  impersonatedBy String? // user_id = admin

  // organization plugin
  activeOrganizationId String? // organization_id

  // additionals
  metadata Json?

  // timestamps
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@index([impersonatedBy])
  @@index([activeOrganizationId])
  @@map("sessions")
}

// ==============================
// BETTER-AUTH ACCOUNTS
// ==============================

model Account {
  id         String @id @default(cuid())
  providerId String // credentials, google, etc
  accountId  String
  userId     String

  // tokens
  accessToken           String?
  refreshToken          String?
  idToken               String?
  accessTokenExpiresAt  DateTime?
  refreshTokenExpiresAt DateTime?

  // credentials
  scope    String?
  password String?

  // additionals
  metadata Json?

  // timestamps
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([providerId, accountId])
  @@index([userId])
  @@map("accounts")
}

// ==============================
// BETTER-AUTH VERIFICATIONS
// ==============================

model Verification {
  id         String   @id @default(cuid())
  identifier String
  value      String
  expiresAt  DateTime

  // timestamps
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([identifier])
  @@map("verifications")
}

// ==============================
// BETTER-AUTH TWO FACTORS
// ==============================

model TwoFactor {
  id          String @id @default(cuid())
  userId      String
  secret      String
  backupCodes String

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@index([secret])
  @@map("two_factors")
}

// ==============================
// BETTER-AUTH API KEYS
// ==============================

model ApiKey {
  id     String  @id @default(cuid())
  userId String
  key    String
  name   String?
  start  String?
  prefix String?

  enabled     Boolean @default(true)
  metadata    String?
  permissions String?

  rateLimitEnabled    Boolean   @default(true)
  rateLimitTimeWindow Int       @default(86400000)
  rateLimitMax        Int       @default(10)
  requestCount        Int       @default(0)
  refillInterval      Int?
  refillAmount        Int?
  lastRefillAt        DateTime?
  remaining           Int?
  lastRequest         DateTime?
  expiresAt           DateTime?

  // timestamps
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@index([key])
  @@index([enabled])
  @@index([rateLimitEnabled])
  @@map("api_keys")
}

// ==============================
// USER ROLES
// ==============================

model UserRole {
  id         String @id @default(cuid())
  role       String @unique
  permission String
  metadata   Json?

  isSystem Boolean @default(false) // system_user_role
  enabled  Boolean @default(true)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([isSystem, enabled])
  @@map("user_roles")
}

// ==============================
// RATE LIMITS
// ==============================

model RateLimit {
  id         String     @id @default(cuid())
  identifier String
  action     ActionType
  metadata   Json?

  limit       Int
  window      Int
  count       Int      @default(1)
  windowStart DateTime @default(now())
  expiresAt   DateTime

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([identifier])
  @@index([action])
  @@map("rate_limits")
}

// ==============================
// ACTIVITY LOGS
// ==============================

model ActivityLog {
  id     String  @id @default(cuid())
  userId String?

  type   ActorType  @default(system)
  actor  String? // snapshot
  entity String
  action ActionType

  changes  Json?
  metadata Json?

  createdAt DateTime @default(now()) // not updated

  user User? @relation(fields: [userId], references: [id], onDelete: SetNull)

  @@index([userId])
  @@index([type])
  @@index([actor])
  @@index([entity, action])
  @@map("activity_logs")
}
