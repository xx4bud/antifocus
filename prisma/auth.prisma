// ==============================
// AUTH ENUMS
// ==============================

enum SystemUserRole {
  user
  admin // global
}

enum UserStatus {
  pending // not verified
  active // verified
  inactive // by user
  deleted // by user
}

enum ActionType {
  create
  update
  delete
  view
  export
  import
  login
  register
  logout
  request
  approve
  reject
  cancel
  complete
  reset
}

enum LogType {
  system
  user
  api_key
  webhook
}

// ==============================
// BETTER-AUTH USERS
// ==============================

model User {
  id            String  @id @default(cuid())
  name          String
  email         String  @unique
  emailVerified Boolean @default(false)
  image         String? // avatar

  // username plugin
  username        String? @unique // slug
  displayUsername String?

  // phone number plugin
  phoneNumber         String? @unique
  phoneNumberVerified Boolean @default(false)

  // admin plugin
  role       String    @default("user") // user_roles
  banned     Boolean   @default(false) // by admin
  banReason  String?
  banExpires DateTime?

  // 2fa plugin
  twoFactorEnabled Boolean @default(false)

  // additionals
  status   UserStatus @default(pending)
  settings Json? // preferences
  metadata Json?

  // timestamps
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  // soft delete
  deletedAt DateTime?

  sessions    Session[]
  accounts    Account[]
  twoFactors  TwoFactor[]
  apiKeys     ApiKey[]
  members     Member[]
  invitations Invitation[]
  customers   Customer[]
  vendors     Vendor[]
  profiles    Profile[]

  @@index([role])
  @@index([status, banned])
  @@index([twoFactorEnabled])
  @@map("users")
}

// ==============================
// BETTER-AUTH SESSIONS
// ==============================

model Session {
  id        String   @id @default(cuid())
  token     String   @unique
  expiresAt DateTime

  // context
  userId    String
  ipAddress String?
  userAgent String?

  // admin plugin
  impersonatedBy String? // user_id = admin

  // organization plugin
  activeOrganizationId String? // organization_id

  // additionals
  metadata Json?

  // timestamps
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@index([impersonatedBy])
  @@index([activeOrganizationId])
  @@map("sessions")
}

// ==============================
// BETTER-AUTH ACCOUNTS
// ==============================

model Account {
  id         String @id @default(cuid())
  providerId String // credentials, google, etc
  accountId  String
  userId     String

  // tokens
  accessToken           String?
  refreshToken          String?
  idToken               String?
  accessTokenExpiresAt  DateTime?
  refreshTokenExpiresAt DateTime?

  // credentials
  scope    String?
  password String?

  // additionals
  metadata Json?

  // timestamps
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([providerId, accountId])
  @@index([userId])
  @@map("accounts")
}

// ==============================
// BETTER-AUTH VERIFICATIONS
// ==============================

model Verification {
  id         String   @id @default(cuid())
  identifier String // email, phone_number, etc
  value      String
  expiresAt  DateTime

  // additionals
  metadata Json?

  // timestamps
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([identifier])
  @@map("verifications")
}

// ==============================
// BETTER-AUTH TWO FACTORS
// ==============================

model TwoFactor {
  id          String @id @default(cuid())
  userId      String
  secret      String
  backupCodes String

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@index([secret])
  @@map("two_factors")
}

// ==============================
// BETTER-AUTH API KEYS
// ==============================

model ApiKey {
  id     String  @id @default(cuid())
  userId String
  key    String
  name   String?
  start  String?
  prefix String?

  // context
  enabled     Boolean @default(true)
  metadata    String?
  permissions String?

  // rate limits
  rateLimitEnabled    Boolean   @default(true)
  rateLimitTimeWindow Int       @default(86400000)
  rateLimitMax        Int       @default(10)
  requestCount        Int       @default(0)
  refillInterval      Int?
  refillAmount        Int?
  lastRefillAt        DateTime?
  remaining           Int?
  lastRequest         DateTime?
  expiresAt           DateTime?

  // timestamps
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@index([key])
  @@index([enabled])
  @@index([rateLimitEnabled])
  @@map("api_keys")
}

// ==============================
// USER ROLES
// ==============================

model UserRole {
  id         String @id @default(cuid())
  role       String @unique
  permission Json // action.entity
  metadata   Json?

  system   Boolean @default(false) // system_user_role
  enabled  Boolean @default(true)
  position Int?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([system, enabled])
  @@map("user_roles")
}

// ==============================
// RATE LIMITS
// ==============================

model RateLimit {
  id         String     @id @default(cuid())
  identifier String
  action     ActionType
  entity     String?
  metadata   Json?

  // rates
  limit       Int
  window      Int
  count       Int      @default(1)
  windowStart DateTime @default(now())
  expiresAt   DateTime

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([identifier])
  @@index([action, entity])
  @@map("rate_limits")
}

// ==============================
// AUDIT LOGS
// ==============================

model AuditLog {
  id        String  @id @default(cuid())
  type      LogType @default(system)
  actor     String // snapshot
  actorId   String?
  ipAddress String?
  userAgent String?

  action ActionType

  entity   String
  entityId String?

  changes  Json?
  metadata Json?

  createdAt DateTime @default(now()) // not updated

  @@index([type])
  @@index([actor])
  @@index([action])
  @@index([entity, entityId])
  @@index([createdAt])
  @@map("audit_logs")
}
