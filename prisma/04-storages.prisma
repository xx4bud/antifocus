// ==============================
// STORAGE ENUMS
// ==============================

enum Storage {
  cloudinary
  cloudflare
  local
}

enum FileType {
  image
  video
  audio
  document
  archive
  other
}

// ==============================
// MEDIAS
// ==============================

model Media {
  id             String @id @default(cuid())
  organizationId String
  name           String
  url            String

  storage Storage @default(local)
  key     String?
  path    String?

  fileType FileType?
  mimeType String?
  width    Int?
  height   Int?
  size     Int?
  dpi      Int?
  metadata Json?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  organization    Organization     @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  productMedias   ProductMedia[]
  variantMedias   VariantMedia[]
  orderItemMedias OrderItemMedia[]
  bannerMedias    BannerMedia[]

  @@index([organizationId])
  @@index([storage])
  @@index([fileType])
  @@index([mimeType])
  @@map("medias")
}

// ==============================
// PRODUCT MEDIAS
// ==============================

model ProductMedia {
  id        String @id @default(cuid())
  mediaId   String
  productId String

  isMain   Boolean @default(false)
  position Int?
  metadata Json?

  media   Media   @relation(fields: [mediaId], references: [id], onDelete: Cascade)
  product Product @relation(fields: [productId], references: [id], onDelete: Cascade)

  @@unique([mediaId, productId])
  @@index([isMain])
  @@map("product_medias")
}

// ==============================
// VARIANT MEDIAS
// ==============================

model VariantMedia {
  id        String @id @default(cuid())
  mediaId   String
  variantId String

  isMain   Boolean @default(false)
  position Int?
  metadata Json?

  media   Media   @relation(fields: [mediaId], references: [id], onDelete: Cascade)
  variant Variant @relation(fields: [variantId], references: [id], onDelete: Cascade)

  @@unique([mediaId, variantId])
  @@index([isMain])
  @@map("variant_medias")
}

// ==============================
// ORDER ITEM MEDIAS
// ==============================

model OrderItemMedia {
  id          String @id @default(cuid())
  mediaId     String
  orderItemId String

  isMain   Boolean @default(false)
  position Int?
  metadata Json?

  media     Media     @relation(fields: [mediaId], references: [id], onDelete: Cascade)
  orderItem OrderItem @relation(fields: [orderItemId], references: [id], onDelete: Cascade)

  @@unique([mediaId, orderItemId])
  @@index([isMain])
  @@map("order_item_medias")
}

// ==============================
// BANNER MEDIAS
// ==============================

model BannerMedia {
  id       String @id @default(cuid())
  mediaId  String
  bannerId String

  media  Media  @relation(fields: [mediaId], references: [id], onDelete: Cascade)
  banner Banner @relation(fields: [bannerId], references: [id], onDelete: Cascade)

  @@unique([mediaId, bannerId])
}
