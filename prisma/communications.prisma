// ==============================
// COMMUNICATIONS ENUMS
// ==============================

enum NotificationType {
  system
  sale
  purchase
  inventory
  payment
  message
}

enum NotificationStatus {
  unread
  read
  archived
}

enum ActivityType {
  todo // "To Do"
  email
  call
  meeting
  reminder
}

// ==============================
// NOTIFICATIONS
// ==============================

model Notification {
  id             String  @id @default(cuid())
  organizationId String
  userId         String // The recipient
  senderId       String? // The sender (if any)

  type    NotificationType @default(system)
  title   String
  message String
  url     String? // link to related record

  status NotificationStatus @default(unread)
  readAt DateTime?

  metadata Json?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  organization Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  user         User         @relation("NotificationUser", fields: [userId], references: [id], onDelete: Cascade)
  sender       User?        @relation("NotificationSender", fields: [senderId], references: [id], onDelete: SetNull)

  @@index([organizationId])
  @@index([userId])
  @@index([status])
  @@index([type])
  @@map("notifications")
}

// ==============================
// ACTIVITIES (TO-DOs)
// ==============================

model Activity {
  id             String @id @default(cuid())
  organizationId String
  assigneeId     String // Who needs to do this

  // Polymorphic relation (what model is this linked to?)
  resModel String? // e.g. "SaleOrder", "Customer", "Lead"
  resId    String? // The ID of the record above

  type    ActivityType @default(todo)
  summary String
  note    String?

  dueDate DateTime
  done    Boolean   @default(false)
  doneAt  DateTime?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  organization Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  assignee     User         @relation("ActivityAssignee", fields: [assigneeId], references: [id], onDelete: Cascade)

  @@index([organizationId])
  @@index([assigneeId])
  @@index([resModel, resId])
  @@index([dueDate])
  @@index([done])
  @@map("activities")
}
