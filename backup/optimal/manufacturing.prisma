// ==============================
// MANUFACTURING ENUMS
// ==============================

enum BomType {
  normal
  kit
  subcontracting
}

enum ManufacturingStatus {
  draft
  confirmed
  in_progress
  done
  canceled
}

enum WorkOrderStatus {
  pending
  in_progress
  done
  canceled
}

// ==============================
// QUALITY ENUMS
// ==============================

enum QualityCheckResult {
  pass
  fail
  warning
}

enum QualityAlertStatus {
  new_alert
  in_progress
  resolved
  closed
}

enum QualityPointType {
  before_production
  during_production
  after_production
  before_shipping
}

// ==============================
// BILL OF MATERIALS
// ==============================

model BillOfMaterial {
  id             String @id @default(cuid())
  organizationId String
  productId      String

  name     String
  type     BomType @default(normal)
  quantity Decimal @default(1)

  // Cost
  operationCost Decimal @default(0)
  totalCost     Decimal @default(0)

  active   Boolean @default(true)
  metadata Json?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  organization Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  product      Product      @relation(fields: [productId], references: [id], onDelete: Cascade)

  lines               BomLine[]
  manufacturingOrders ManufacturingOrder[]

  @@index([organizationId])
  @@index([productId])
  @@index([type])
  @@map("bill_of_materials")
}

// ==============================
// BOM LINES (Components)
// ==============================

model BomLine {
  id    String @id @default(cuid())
  bomId String

  productId String
  variantId String?

  quantity Decimal @default(1)
  position Int     @default(0)
  note     String?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  bom     BillOfMaterial @relation(fields: [bomId], references: [id], onDelete: Cascade)
  product Product        @relation(fields: [productId], references: [id])
  variant Variant?       @relation(fields: [variantId], references: [id])

  @@index([bomId])
  @@index([productId])
  @@map("bom_lines")
}

// ==============================
// MANUFACTURING ORDERS
// ==============================

model ManufacturingOrder {
  id             String  @id @default(cuid())
  organizationId String
  bomId          String?
  saleOrderId    String?

  name     String
  status   ManufacturingStatus @default(draft)
  quantity Decimal             @default(1)
  priority Int                 @default(0)

  // Dates
  scheduledStart DateTime?
  scheduledEnd   DateTime?
  actualStart    DateTime?
  actualEnd      DateTime?

  note     String?
  metadata Json?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  organization Organization    @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  bom          BillOfMaterial? @relation(fields: [bomId], references: [id], onDelete: SetNull)
  saleOrder    SaleOrder?      @relation(fields: [saleOrderId], references: [id], onDelete: SetNull)

  workOrders    WorkOrder[]
  qualityChecks QualityCheck[]

  @@unique([organizationId, name])
  @@index([organizationId])
  @@index([bomId])
  @@index([saleOrderId])
  @@index([status])
  @@map("manufacturing_orders")
}

// ==============================
// WORK ORDERS
// ==============================

model WorkOrder {
  id                   String @id @default(cuid())
  manufacturingOrderId String

  name     String
  status   WorkOrderStatus @default(pending)
  sequence Int             @default(0)

  duration    Decimal? // minutes
  actualStart DateTime?
  actualEnd   DateTime?

  instructions String?
  note         String?
  metadata     Json?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  manufacturingOrder ManufacturingOrder @relation(fields: [manufacturingOrderId], references: [id], onDelete: Cascade)

  @@index([manufacturingOrderId])
  @@index([status])
  @@map("work_orders")
}

// ==============================
// QUALITY POINTS (Where to check)
// ==============================

model QualityPoint {
  id             String  @id @default(cuid())
  organizationId String
  productId      String?

  name String
  type QualityPointType @default(after_production)

  instructions String?
  criteria     String?
  testType     String?

  active   Boolean @default(true)
  position Int     @default(0)
  metadata Json?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  organization Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  product      Product?     @relation(fields: [productId], references: [id], onDelete: SetNull)

  checks QualityCheck[]

  @@index([organizationId])
  @@index([productId])
  @@index([type])
  @@map("quality_points")
}

// ==============================
// QUALITY CHECKS
// ==============================

model QualityCheck {
  id                   String  @id @default(cuid())
  organizationId       String
  qualityPointId       String
  manufacturingOrderId String?
  stockPickingId       String?

  result  QualityCheckResult @default(pass)
  note    String?
  images  String[]
  measure Decimal?

  inspectorId String?
  checkedAt   DateTime @default(now())

  metadata Json?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  organization       Organization        @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  qualityPoint       QualityPoint        @relation(fields: [qualityPointId], references: [id])
  manufacturingOrder ManufacturingOrder? @relation(fields: [manufacturingOrderId], references: [id], onDelete: SetNull)
  stockPicking       StockPicking?       @relation(fields: [stockPickingId], references: [id], onDelete: SetNull)
  inspector          User?               @relation("QualityInspector", fields: [inspectorId], references: [id], onDelete: SetNull)

  alerts QualityAlert[]

  @@index([organizationId])
  @@index([qualityPointId])
  @@index([manufacturingOrderId])
  @@index([stockPickingId])
  @@index([result])
  @@map("quality_checks")
}

// ==============================
// QUALITY ALERTS
// ==============================

model QualityAlert {
  id             String  @id @default(cuid())
  organizationId String
  checkId        String?
  productId      String?

  name        String
  description String?
  status      QualityAlertStatus @default(new_alert)
  priority    String?            @default("medium")

  rootCause        String?
  correctiveAction String?

  assigneeId String?

  metadata Json?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  organization Organization  @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  check        QualityCheck? @relation(fields: [checkId], references: [id], onDelete: SetNull)
  product      Product?      @relation(fields: [productId], references: [id], onDelete: SetNull)
  assignee     User?         @relation("QualityAlertAssignee", fields: [assigneeId], references: [id], onDelete: SetNull)

  @@index([organizationId])
  @@index([checkId])
  @@index([productId])
  @@index([status])
  @@map("quality_alerts")
}
