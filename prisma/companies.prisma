// ==============================
// BETTER-AUTH ORGANIZATIONS
// ==============================

enum SystemOrgRole {
  member
  admin // per company
  owner
}

enum OrganizationStatus {
  pending // not verified
  active // verified
  inactive // by user
  deleted // by user
}

enum InvitationStatus {
  pending
  accepted
  rejected
  canceled
}

enum StoreStatus {
  open
  vacation
  closed
  maintenance
}

enum StoreType {
  retail
  warehouse
  office
}

// ==============================
// BETTER-AUTH ORGANIZATIONS
// ==============================

model Organization {
  id       String  @id @default(cuid())
  name     String
  slug     String  @unique
  logo     String?
  metadata Json?

  // additionals
  status OrganizationStatus @default(pending)
  banned Boolean            @default(false)

  // timestamps
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  // soft delete
  deletedAt DateTime?

  settings          Setting[]
  organizationRoles OrganizationRole[]
  members           Member[]
  invitations       Invitation[]
  stores            Store[]
  customers         Customer[]
  vendors           Vendor[]
  profiles          Profile[]
  addresses         Address[]
  socials           Social[]
  bankAccounts      BankAccount[]
  units             Unit[]
  categories        Category[]
  attributes        Attribute[]
  options           Option[]
  products          Product[]
  variants          Variant[]
  values            Value[]
  collections       Collection[]
  tags              Tag[]
  medias            Media[]
  banners           Banner[]

  @@index([status, banned])
  @@map("organizations")
}

// ==============================
// BETTER-AUTH ORGANIZATION ROLES
// ==============================

model OrganizationRole {
  id             String @id @default(cuid())
  organizationId String
  role           String
  permission     Json // action.entity
  metadata       Json?

  // additionals
  system   Boolean @default(false) // system_org_role
  enabled  Boolean @default(true)
  position Int?

  // timestamps
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  organization Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)

  @@unique([organizationId, role])
  @@index([system, enabled])
  @@map("org_roles")
}

// ==============================
// BETTER-AUTH MEMBERS
// ==============================

model Member {
  id             String @id @default(cuid())
  organizationId String
  userId         String
  role           String @default("member") // org_roles

  // additionals
  enabled  Boolean @default(true)
  metadata Json?

  // timestamps
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  organization Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  user         User         @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([organizationId, userId])
  @@index([enabled])
  @@map("members")
}

// ==============================
// BETTER-AUTH INVITATIONS
// ==============================

model Invitation {
  id             String @id @default(cuid())
  organizationId String
  inviterId      String

  // targets
  email     String
  role      String           @default("member")
  status    InvitationStatus @default(pending)
  expiresAt DateTime

  // additionals
  metadata Json?

  // timestamps
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  organization Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  inviter      User         @relation(fields: [inviterId], references: [id], onDelete: Cascade)

  @@unique([organizationId, email])
  @@index([inviterId])
  @@index([status])
  @@map("invitations")
}

// ==============================
// CUSTOMERS
// ==============================

model Customer {
  id             String  @id @default(cuid())
  organizationId String
  userId         String? // online customer
  image          String?
  cover          String?

  enabled  Boolean  @default(true)
  tags     String[]
  metadata Json?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  organization Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  user         User?        @relation(fields: [userId], references: [id], onDelete: SetNull)

  profiles Profile[]

  @@unique([organizationId, userId])
  @@index([enabled])
  @@map("customers")
}

// ==============================
// VENDORS
// ==============================

model Vendor {
  id             String  @id @default(cuid())
  organizationId String
  userId         String? // vendor person
  image          String?
  cover          String?

  enabled  Boolean  @default(true)
  tags     String[]
  metadata Json?

  organization Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  user         User?        @relation(fields: [userId], references: [id], onDelete: SetNull)

  profiles Profile[]

  @@unique([organizationId, userId])
  @@index([enabled])
  @@map("vendors")
}
