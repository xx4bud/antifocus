{
  "name": "antifocus",
  "version": "0.0.0",
  "private": true,
  "scripts": {
    "dev": "pnpm with:env next dev --turbo --port 3000",
    "build": "git clean -xdf .next && pnpm with:env next build",
    "start": "pnpm with:env next start",
    "clean": "git clean -xdf .turbo .next .cache node_modules",
    "check:lint": "ultracite fix --unsafe .",
    "check:types": "pnpm with:env next typegen && tsc --noEmit",
    "check:all": "pnpm check:lint && pnpm check:types",
    "with:env": "dotenv -e .env --",
    "ui:generate": "pnpm dlx shadcn@latest add",
    "auth:generate": "pnpm with:env npx @better-auth/cli generate --config src/lib/auth/index.ts",
    "db:generate": "pnpm with:env drizzle-kit generate",
    "db:push": "pnpm with:env drizzle-kit push",
    "db:studio": "pnpm with:env drizzle-kit studio",
    "prepare": "husky"
  },
  "dependencies": {
    "@base-ui/react": "^1.5.0",
    "@better-auth/api-key": "^1.6.16",
    "@date-fns/tz": "^1.5.0",
    "@neondatabase/serverless": "^1.1.0",
    "@node-rs/argon2": "^2.0.2",
    "@paralleldrive/cuid2": "^3.3.0",
    "@t3-oss/env-nextjs": "^0.13.11",
    "@tabler/icons-react": "^3.44.0",
    "@tanstack/react-form": "^1.33.0",
    "@tanstack/react-query": "^5.101.0",
    "@trpc/client": "^11.17.0",
    "@trpc/react-query": "^11.17.0",
    "@trpc/server": "^11.17.0",
    "@trpc/tanstack-react-query": "^11.17.0",
    "@upstash/redis": "^1.38.0",
    "better-auth": "^1.6.16",
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "cmdk": "^1.1.1",
    "date-fns": "^4.4.0",
    "dinero.js": "^2.0.2",
    "drizzle-orm": "^0.45.2",
    "embla-carousel-react": "^8.6.0",
    "inngest": "^4.5.1",
    "input-otp": "^1.4.2",
    "libphonenumber-js": "^1.13.6",
    "motion": "^12.40.0",
    "next": "16.2.7",
    "next-intl": "^4.13.0",
    "next-themes": "^0.4.6",
    "radix-ui": "^1.4.3",
    "react": "19.2.4",
    "react-day-picker": "^10.0.1",
    "react-dom": "19.2.4",
    "react-email": "^6.6.0",
    "react-resizable-panels": "^4.11.2",
    "recharts": "3.8.0",
    "resend": "^6.12.4",
    "shadcn": "^4.10.0",
    "sonner": "^2.0.7",
    "superjson": "^2.2.6",
    "tailwind-merge": "^3.6.0",
    "tw-animate-css": "^1.4.0",
    "uploadthing": "^7.7.4",
    "vaul": "^1.1.2",
    "zod": "^4.4.3"
  },
  "devDependencies": {
    "@biomejs/biome": "2.4.15",
    "@commitlint/cli": "^21.0.2",
    "@commitlint/config-conventional": "^21.0.2",
    "@tailwindcss/postcss": "^4.3.0",
    "@types/node": "^22.19.19",
    "@types/react": "^19.2.3",
    "@types/react-dom": "^19.2.3",
    "babel-plugin-react-compiler": "1.0.0",
    "dotenv-cli": "^11.0.0",
    "drizzle-kit": "^0.31.10",
    "husky": "^9.1.7",
    "lint-staged": "^17.0.7",
    "tailwindcss": "^4.3.0",
    "tsx": "^4.22.4",
    "typescript": "^6.0.3",
    "ultracite": "7.8.1"
  },
  "engines": {
    "node": ">=22",
    "pnpm": ">=10"
  },
  "packageManager": "pnpm@10.33.0"
}
