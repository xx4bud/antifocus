// ==============================
// AUTH ENUMS
// ==============================

enum SystemUserRole {
  user
  admin // global
}

enum UserStatus {
  pending // not verified
  active // verified
  inactive // by user
  deleted // by user
}

enum ActionType {
  create
  update
  delete
  view
  export
  import
  login
  register
  logout
  request
  approve
  reject
  cancel
  complete
  reset
}

enum LogType {
  system
  user
  api_key
  webhook
}

// ==============================
// BETTER-AUTH USERS
// ==============================

model User {
  id            String  @id @default(cuid())
  name          String
  email         String  @unique
  emailVerified Boolean @default(false)
  image         String? // avatar

  // username plugin
  username        String? @unique // slug
  displayUsername String?

  // phone number plugin
  phoneNumber         String? @unique
  phoneNumberVerified Boolean @default(false)

  // admin plugin
  role       String    @default("user") // user_roles
  banned     Boolean   @default(false) // by admin
  banReason  String?
  banExpires DateTime?

  // 2fa plugin
  twoFactorEnabled Boolean @default(false)

  // additionals
  status   UserStatus @default(pending)
  settings Json? // preferences
  metadata Json?

  // timestamps
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  // soft delete
  deletedAt DateTime?

  sessions    Session[]
  accounts    Account[]
  twoFactors  TwoFactor[]
  apiKeys     ApiKey[]
  members     Member[]
  invitations Invitation[]
  customers   Customer[]
  vendors     Vendor[]
  profiles    Profile[]
  carts       Cart[]

  // Communications
  notificationsReceived Notification[] @relation("NotificationUser")
  notificationsSent     Notification[] @relation("NotificationSender")
  activitiesAssigned    Activity[]     @relation("ActivityAssignee")

  // HR
  employeeProfile Employee? @relation("UserEmployee")

  // CRM
  leadsManaged Lead[]

  // Helpdesk
  assignedTickets Ticket[]        @relation("TicketAssignee")
  ticketMessages  TicketMessage[] @relation("TicketMessageAuthor")

  // Quality
  qualityChecks QualityCheck[] @relation("QualityInspector")
  qualityAlerts QualityAlert[] @relation("QualityAlertAssignee")

  // Projects
  managedProjects Project[]     @relation("ProjectManager")
  assignedTasks   ProjectTask[] @relation("TaskAssignee")

  // POS
  posSessions PosSession[] @relation("PosCashier")

  // Messaging
  messageLogs MessageLog[] @relation("MessageSender")

  // Website
  webPages  WebPage[]  @relation("PageAuthor")
  blogPosts BlogPost[] @relation("BlogAuthor")

  // Expenses
  expenseApprovals ExpenseReport[] @relation("ExpenseApprover")

  // Leaves
  leaveApprovals LeaveRequest[] @relation("LeaveApprover")

  // Approvals
  approvalRequests ApprovalRequest[] @relation("ApprovalRequester")
  approverActions  Approver[]        @relation("ApproverUser")

  // Documents
  ownedDocuments DocumentRecord[] @relation("DocumentOwner")

  // Surveys
  createdSurveys  Survey[]         @relation("SurveyAuthor")
  surveyResponses SurveyResponse[] @relation("SurveyRespondent")

  // Maintenance
  maintenanceRequests MaintenanceRequest[] @relation("MaintenanceRequester")
  maintenanceAssigned MaintenanceRequest[] @relation("MaintenanceTechnician")

  // Recruitment
  recruiterApplications JobApplication[]    @relation("RecruiterApplications")
  interviewerSchedules  InterviewSchedule[] @relation("InterviewerSchedules")

  // Knowledge Base
  knowledgeArticles KnowledgeArticle[] @relation("KnowledgeAuthor")

  // Reports
  savedReports SavedReport[] @relation("SavedReportAuthor")

  // Discussions
  channelMemberships ChannelMember[]     @relation("ChannelMemberships")
  discussionMessages DiscussionMessage[] @relation("DiscussionAuthor")
  recordFollowers    Follower[]          @relation("RecordFollower")
  recordNotes        RecordNote[]        @relation("RecordNoteAuthor")
  dataExportJobs     DataExportJob[]     @relation("DataExportRequester")
  dataImportJobs     DataImportJob[]     @relation("DataImportRequester")
  workflowHistories  WorkflowHistory[]

  @@index([email])
  @@index([role])
  @@index([status, banned])
  @@index([twoFactorEnabled])
  @@map("users")
}

// ==============================
// BETTER-AUTH SESSIONS
// ==============================

model Session {
  id        String   @id @default(cuid())
  token     String   @unique
  expiresAt DateTime

  // context
  userId    String
  ipAddress String?
  userAgent String?

  // admin plugin
  impersonatedBy String? // user_id = admin

  // organization plugin
  activeOrganizationId String? // organization_id

  // additionals
  metadata Json?

  // timestamps
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@index([impersonatedBy])
  @@index([activeOrganizationId])
  @@index([expiresAt])
  @@map("sessions")
}

// ==============================
// BETTER-AUTH ACCOUNTS
// ==============================

model Account {
  id         String @id @default(cuid())
  providerId String // credentials, google, etc
  accountId  String
  userId     String

  // tokens
  accessToken           String?
  refreshToken          String?
  idToken               String?
  accessTokenExpiresAt  DateTime?
  refreshTokenExpiresAt DateTime?

  // credentials
  scope    String?
  password String?

  // additionals
  metadata Json?

  // timestamps
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([providerId, accountId])
  @@index([userId])
  @@map("accounts")
}

// ==============================
// BETTER-AUTH VERIFICATIONS
// ==============================

model Verification {
  id         String   @id @default(cuid())
  identifier String // email, phone_number, etc
  value      String
  expiresAt  DateTime

  // additionals
  metadata Json?

  // timestamps
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([identifier])
  @@index([expiresAt])
  @@map("verifications")
}

// ==============================
// BETTER-AUTH TWO FACTORS
// ==============================

model TwoFactor {
  id          String @id @default(cuid())
  userId      String
  secret      String
  backupCodes String

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@index([secret])
  @@map("two_factors")
}

// ==============================
// BETTER-AUTH API KEYS
// ==============================

model ApiKey {
  id     String  @id @default(cuid())
  userId String
  key    String  @unique
  name   String?
  start  String?
  prefix String?

  // context
  enabled     Boolean @default(true)
  metadata    String?
  permissions String?

  // rate limits
  rateLimitEnabled    Boolean   @default(true)
  rateLimitTimeWindow Int       @default(86400000)
  rateLimitMax        Int       @default(10)
  requestCount        Int       @default(0)
  refillInterval      Int?
  refillAmount        Int?
  lastRefillAt        DateTime?
  remaining           Int?
  lastRequest         DateTime?
  expiresAt           DateTime?

  // timestamps
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@index([key])
  @@index([enabled])
  @@index([rateLimitEnabled])
  @@map("api_keys")
}

// ==============================
// USER ROLES
// ==============================

model UserRole {
  id         String @id @default(cuid())
  role       String @unique
  permission Json // action.entity
  metadata   Json?

  system   Boolean @default(false) // system_user_role
  enabled  Boolean @default(true)
  position Int?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([system, enabled])
  @@map("user_roles")
}

// ==============================
// RATE LIMITS
// ==============================

model RateLimit {
  id         String     @id @default(cuid())
  identifier String
  action     ActionType
  entity     String?
  metadata   Json?

  // rates
  limit       Int
  window      Int
  count       Int      @default(1)
  windowStart DateTime @default(now())
  expiresAt   DateTime

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([identifier])
  @@index([identifier, action])
  @@index([action, entity])
  @@index([expiresAt])
  @@map("rate_limits")
}

// ==============================
// AUDIT LOGS
// ==============================

model AuditLog {
  id             String  @id @default(cuid())
  organizationId String?
  type           LogType @default(system)
  actor          String // snapshot
  actorId        String?
  ipAddress      String?
  userAgent      String?

  action ActionType

  entity   String
  entityId String?

  // Change details
  changes       Json? // Full diff
  oldValues     Json? // Previous values
  newValues     Json? // New values
  changedFields String[] // Changed field names

  // Context
  endpoint String? // API route
  source   String? // web, api, system, import

  metadata Json?

  createdAt DateTime @default(now()) // not updated

  @@index([organizationId])
  @@index([type])
  @@index([actor])
  @@index([action])
  @@index([entity, entityId])
  @@index([createdAt])
  @@map("audit_logs")
}
