{
  "name": "antifocus",
  "type": "module",
  "private": true,
  "scripts": {
    "with:env": "dotenv -e .env --",
    "dev": "pnpm with:env next dev",
    "build": "pnpm with:env next build",
    "start": "pnpm with:env next start",
    "clean": "git clean -xdf .cache .next node_modules",
    "check:lint": "ultracite fix",
    "check:types": "pnpm with:env next typegen && tsc --noEmit",
    "check:all": "pnpm check:lint && pnpm check:types",
    "ui:add": "pnpm dlx shadcn@latest add",
    "auth:generate": "dotenv -e .env -- pnpx @better-auth/cli generate --config src/lib/auth/index.ts --output better-auth.ts --yes",
    "db:push": "pnpm with:env drizzle-kit push --config drizzle.config.ts",
    "db:generate": "pnpm with:env drizzle-kit generate --config drizzle.config.ts",
    "db:migrate": "pnpm with:env drizzle-kit migrate --config drizzle.config.ts",
    "db:seed": "pnpm with:env tsx scripts/seed-main.ts",
    "prepare": "husky"
  },
  "dependencies": {
    "@dnd-kit/core": "^6.3.1",
    "@dnd-kit/modifiers": "^9.0.0",
    "@dnd-kit/sortable": "^10.0.0",
    "@dnd-kit/utilities": "^3.2.2",
    "@neondatabase/serverless": "^1.0.2",
    "@node-rs/argon2": "^2.0.2",
    "@paralleldrive/cuid2": "^3.3.0",
    "@t3-oss/env-nextjs": "^0.13.11",
    "@tabler/icons-react": "^3.41.1",
    "@tanstack/react-table": "^8.21.3",
    "@trpc/server": "^11.16.0",
    "better-auth": "^1.5.6",
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "drizzle-orm": "^0.45.2",
    "next": "16.2.2",
    "next-intl": "^4.9.0",
    "next-themes": "^0.4.6",
    "radix-ui": "^1.4.3",
    "react": "19.2.4",
    "react-dom": "19.2.4",
    "recharts": "3.8.0",
    "shadcn": "^4.1.2",
    "sonner": "^2.0.7",
    "tailwind-merge": "^3.5.0",
    "tw-animate-css": "^1.4.0",
    "vaul": "^1.1.2",
    "zod": "^4.3.6"
  },
  "devDependencies": {
    "@biomejs/biome": "2.4.10",
    "@commitlint/cli": "^20.5.0",
    "@commitlint/config-conventional": "^20.5.0",
    "@tailwindcss/postcss": "^4.2.0",
    "@types/node": "^22.19.0",
    "@types/react": "^19.2.3",
    "@types/react-dom": "^19.2.3",
    "babel-plugin-react-compiler": "1.0.0",
    "dotenv-cli": "^11.0.0",
    "drizzle-kit": "^0.31.10",
    "husky": "^9.1.7",
    "jiti": "^2.6.1",
    "tailwindcss": "^4.2.0",
    "tsx": "^4.21.0",
    "typescript": "^5.9.3",
    "ultracite": "7.4.3"
  },
  "commitlint": {
    "extends": [
      "@commitlint/config-conventional"
    ]
  },
  "engines": {
    "node": ">=22.x",
    "pnpm": ">=10.x"
  },
  "packageManager": "pnpm@10.33.0"
}
