{
  "name": "antifocus",
  "type": "module",
  "private": true,
  "scripts": {
    "dev": "next dev",
    "build": "next build",
    "start": "next start",
    "clean": "git clean -xdf .cache .next",
    "check:lint": "ultracite fix",
    "check:types": "next typegen && tsc --noEmit",
    "check:all": "pnpm check:lint && pnpm check:types",
    "prepare": "husky"
  },
  "dependencies": {
    "next": "16.2.1",
    "react": "19.2.4",
    "react-dom": "19.2.4"
  },
  "devDependencies": {
    "@biomejs/biome": "2.4.9",
    "@commitlint/cli": "^20.5.0",
    "@commitlint/config-conventional": "^20.5.0",
    "@tailwindcss/postcss": "^4.2.0",
    "@types/node": "^22.19.0",
    "@types/react": "^19.2.3",
    "@types/react-dom": "^19.2.3",
    "babel-plugin-react-compiler": "1.0.0",
    "husky": "^9.1.7",
    "lint-staged": "^16.4.0",
    "tailwindcss": "^4.2.0",
    "typescript": "^5.9.3",
    "ultracite": "7.4.0"
  },
  "commitlint": {
    "extends": [
      "@commitlint/config-conventional"
    ]
  },
  "lint-staged": {
    "*.{js,jsx,ts,tsx,json,jsonc,css,scss,md,mdx}": [
      "pnpm check:lint"
    ]
  },
  "engines": {
    "node": ">=22.x",
    "pnpm": ">=10.x"
  },
  "packageManager": "pnpm@10.33.0"
}
