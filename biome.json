{
  "$schema": "./node_modules/@biomejs/biome/configuration_schema.json",
  "extends": ["ultracite/core"],
  "files": {
    "ignoreUnknown": false,
    "includes": [
      "**",
      "!**/node_modules",
      "!**/dist",
      "!**/build",
      "!**/.cache",
      "!**/.turbo",
      "!**/.next",
      "!**/.vercel"
    ]
  },
  "linter": {
    "rules": {
      "style": {
        "noExportedImports": "off"
      }
    }
  }
}
