{
  "name": "antifocus",
  "version": "0.0.0",
  "private": true,
  "scripts": {
    "dev": "pnpm with:env next dev --port 3000",
    "build": "pnpm with:env next build",
    "start": "pnpm with:env next start",
    "clean": "git clean -xdf .turbo .next .cache node_modules",
    "check:lint": "ultracite fix --unsafe .",
    "check:types": "pnpm with:env next typegen && tsc --noEmit",
    "check:all": "pnpm check:lint && pnpm check:types",
    "with:env": "dotenv -e .env --",
    "prepare": "husky"
  },
  "dependencies": {
    "@tabler/icons-react": "^3.44.0",
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "next": "16.2.7",
    "radix-ui": "^1.4.3",
    "react": "19.2.4",
    "react-dom": "19.2.4",
    "shadcn": "^4.10.0",
    "tailwind-merge": "^3.6.0",
    "tw-animate-css": "^1.4.0"
  },
  "devDependencies": {
    "@biomejs/biome": "2.4.15",
    "@commitlint/cli": "^21.0.2",
    "@commitlint/config-conventional": "^21.0.2",
    "@tailwindcss/postcss": "^4.3.0",
    "@types/node": "^22.19.19",
    "@types/react": "^19.2.3",
    "@types/react-dom": "^19.2.3",
    "babel-plugin-react-compiler": "1.0.0",
    "dotenv-cli": "^11.0.0",
    "husky": "^9.1.7",
    "lint-staged": "^17.0.7",
    "tailwindcss": "^4.3.0",
    "typescript": "^6.0.3",
    "ultracite": "7.8.1"
  }
}
