// ==============================
// SALE ENUMS
// ==============================

enum OrderStatus {
  pending
  confirmed
  processing
  printing
  quality_check
  packing
  shipped
  delivered
  completed
  cancelled
  refunded
  on_hold
}

// ==============================
// CHANNELS
// ==============================

model Channel {
  id             String  @id @default(cuid())
  organizationId String
  name           String
  slug           String  @unique
  image          String?
  metadata       Json?

  enabled  Boolean @default(true)
  position Int?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  organization Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)

  orders Order[]

  @@index([organizationId])
  @@index([enabled])
  @@map("channels")
}

// ==============================
// ORDERS
// ==============================

model Order {
  id             String @id @default(cuid())
  organizationId String
  customerId     String
  channelId      String

  orderNumber String

  subTotal       Decimal @db.Decimal(19, 8)
  discountAmount Decimal @db.Decimal(19, 8)
  taxAmount      Decimal @db.Decimal(19, 8)
  shippingAmount Decimal @db.Decimal(19, 8)
  total          Decimal @db.Decimal(19, 8)

  currencyCode String  @default("IDR")
  exchangeRate Decimal @default(1) @db.Decimal(19, 8)

  shippingAddress Json?
  billingAddress  Json?

  createdAt DateTime  @default(now())
  updatedAt DateTime  @updatedAt
  deletedAt DateTime?
  createdBy String?
  updatedBy String?
  deletedBy String?

  customerNotes String?
  internalNotes String?
  metadata      Json?

  organization Organization @relation(fields: [organizationId], references: [id], onDelete: Restrict)
  customer     Customer     @relation(fields: [customerId], references: [id], onDelete: Restrict)
  channel      Channel      @relation(fields: [channelId], references: [id], onDelete: Cascade)

  payments     Payment[]
  refunds      Refund[]
  transactions PosTransaction[]
  orderItems   OrderItem[]

  @@map("orders")
}

// ==============================
// ORDER ITEMS
// ==============================

model OrderItem {
  id        String  @id @default(cuid())
  orderId   String
  productId String?
  variantId String?

  productName String?
  variantName String?
  sku         String?
  quantity    Int     @default(1)

  unitPrice      Decimal @db.Decimal(19, 8)
  discountAmount Decimal @db.Decimal(19, 8)
  taxAmount      Decimal @db.Decimal(19, 8)
  total          Decimal @db.Decimal(19, 8)

  createdAt DateTime  @default(now())
  updatedAt DateTime  @updatedAt
  deletedAt DateTime?
  createdBy String?
  updatedBy String?
  deletedBy String?

  order   Order    @relation(fields: [orderId], references: [id], onDelete: Cascade)
  product Product? @relation(fields: [productId], references: [id], onDelete: Restrict)
  variant Variant? @relation(fields: [variantId], references: [id], onDelete: Restrict)

  medias OrderItemMedia[]

  @@map("order_items")
}
