// ==============================
// SHIPPING ENUMS
// ==============================

enum ShipmentStatus {
  pending
  picked_up
  in_transit
  out_for_delivery
  delivered
  failed
  returned
}

enum ShippingType {
  standard
  express
  same_day
  economy
  free
  pickup
}

// ==============================
// RETURN ENUMS
// ==============================

enum ReturnStatus {
  requested
  approved
  rejected
  received
  refunded
  exchanged
  canceled
}

enum ReturnReason {
  damaged
  defective
  wrong_item
  not_as_described
  change_of_mind
  late_delivery
  other
}

enum ReturnType {
  refund
  exchange
  store_credit
}

// ==============================
// SHIPPING METHODS
// ==============================

model ShippingMethod {
  id             String @id @default(cuid())
  organizationId String

  name        String
  code        String
  carrier     String? // JNE, J&T, SiCepat, GoSend
  type        ShippingType @default(standard)
  description String?

  // Pricing
  flatRate   Decimal  @default(0)
  freeAbove  Decimal? // Free shipping above this amount
  priceRules Json? // Weight/distance-based rules

  // Delivery
  estimatedDays Int?

  // Integration
  apiEndpoint String?
  apiKey      String?

  enabled  Boolean @default(true)
  position Int     @default(0)
  metadata Json?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  organization Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  shipments    Shipment[]

  @@unique([organizationId, code])
  @@index([organizationId])
  @@index([type])
  @@index([enabled])
  @@map("shipping_methods")
}

// ==============================
// SHIPMENTS
// ==============================

model Shipment {
  id               String  @id @default(cuid())
  organizationId   String
  saleOrderId      String?
  shippingMethodId String?

  trackingNumber String?
  status         ShipmentStatus @default(pending)

  // Weight & dimensions
  weight Decimal @default(0)
  length Decimal @default(0)
  width  Decimal @default(0)
  height Decimal @default(0)

  // Cost
  shippingCost Decimal @default(0)
  insurance    Decimal @default(0)

  // Addresses
  senderAddress    Json?
  recipientAddress Json?

  // Dates
  shippedAt   DateTime?
  deliveredAt DateTime?
  estimatedAt DateTime?

  note     String?
  metadata Json?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  organization   Organization    @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  saleOrder      SaleOrder?      @relation(fields: [saleOrderId], references: [id], onDelete: SetNull)
  shippingMethod ShippingMethod? @relation(fields: [shippingMethodId], references: [id], onDelete: SetNull)

  tracking ShipmentTracking[]

  @@index([organizationId])
  @@index([saleOrderId])
  @@index([trackingNumber])
  @@index([status])
  @@map("shipments")
}

// ==============================
// SHIPMENT TRACKING
// ==============================

model ShipmentTracking {
  id         String @id @default(cuid())
  shipmentId String

  status      String
  description String?
  location    String?

  eventAt DateTime @default(now())

  metadata Json?

  createdAt DateTime @default(now())

  shipment Shipment @relation(fields: [shipmentId], references: [id], onDelete: Cascade)

  @@index([shipmentId])
  @@index([eventAt])
  @@map("shipment_tracking")
}

// ==============================
// RETURN ORDERS
// ==============================

model ReturnOrder {
  id             String  @id @default(cuid())
  organizationId String
  saleOrderId    String
  customerId     String?
  profileId      String?

  returnNumber String
  status       ReturnStatus @default(requested)
  type         ReturnType   @default(refund)

  // Financials
  refundAmount  Decimal @default(0)
  restockingFee Decimal @default(0)

  // Dates
  requestDate  DateTime  @default(now())
  approvalDate DateTime?
  receiveDate  DateTime?
  refundDate   DateTime?

  reason   ReturnReason @default(other)
  note     String?
  proof    String[]
  metadata Json?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  organization Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  saleOrder    SaleOrder    @relation(fields: [saleOrderId], references: [id])
  customer     Customer?    @relation(fields: [customerId], references: [id], onDelete: SetNull)

  lines ReturnOrderLine[]

  @@unique([organizationId, returnNumber])
  @@index([saleOrderId])
  @@index([customerId])
  @@index([status])
  @@index([requestDate])
  @@map("return_orders")
}

// ==============================
// RETURN ORDER LINES
// ==============================

model ReturnOrderLine {
  id            String @id @default(cuid())
  returnOrderId String
  productId     String
  variantId     String

  quantity         Decimal      @default(1)
  quantityReceived Decimal      @default(0)
  unitPrice        Decimal      @default(0)
  reason           ReturnReason @default(other)
  note             String?
  metadata         Json?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  returnOrder ReturnOrder @relation(fields: [returnOrderId], references: [id], onDelete: Cascade)
  product     Product     @relation(fields: [productId], references: [id])
  variant     Variant     @relation(fields: [variantId], references: [id])

  @@index([returnOrderId])
  @@index([productId])
  @@index([variantId])
  @@map("return_order_lines")
}
