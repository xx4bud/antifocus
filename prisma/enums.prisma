// just schema blueprint

generator client {
    provider = "prisma-client-js"
}

datasource db {
    provider = "postgresql"
    //url    = env("DATABASE_URL") // deprecated in prisma v7
}

// ==============================
// Base
// ==============================

enum EntityStatus {
    active
    inactive

    @@map("entity_status")
}

enum CurrencyCode {
    IDR
    USD

    @@map("currency_code")
}

// ==============================
// Auth
// ==============================

enum UserRole {
    user
    superadmin

    @@map("user_role")
}

// ==============================
// Org
// ==============================

enum OrgRole {
    member
    admin
    owner

    @@map("org_role")
}

enum InvitationStatus {
    pending
    accepted
    rejected
    canceled

    @@map("invitation_status")
}

// ==============================
// Contact
// ==============================

enum BranchStatus {
    open
    closed

    @@map("branch_status")
}

// ==============================
// Taxonomy
// ==============================

enum AttributeType {
    select
    text
    number
    boolean
    color

    @@map("attribute_type")
}

// ==============================
// Catalog
// ==============================

enum ProductStatus {
    draft
    live
    archived

    @@map("product_status")
}

// ==============================
// Order
// ==============================

enum OrderStatus {
    pending
    paid
    producing
    shipped
    completed
    canceled

    @@map("order_status")
}

// ==============================
// Invoice
// ==============================

enum InvoiceStatus {
    draft
    issued
    paid
    partially_paid
    overdue
    voided

    @@map("invoice_status")
}

enum PaymentMethod {
    cash
    bank_transfer
    ewallet
    credit_card
    other

    @@map("payment_method")
}

enum PaymentStatus {
    pending
    completed
    failed
    refunded

    @@map("payment_status")
}

// ==============================
// Fulfillment
// ==============================

enum FulfillmentStatus {
    pending
    processing
    packed
    shipped
    delivered
    canceled

    @@map("fulfillment_status")
}

// ==============================
// Inventory
// ==============================

enum MovementType {
    inbound
    outbound
    adjustment

    @@map("movement_type")
}

enum PurchaseOrderStatus {
    draft
    ordered
    partially_received
    received
    canceled

    @@map("purchase_order_status")
}

// ==============================
// Production
// ==============================

enum ProductionOrderStatus {
    draft
    scheduled
    in_progress
    completed
    canceled

    @@map("production_order_status")
}
