{
  "name": "antifocus",
  "type": "module",
  "private": true,
  "scripts": {
    "dev": "pnpm  next dev",
    "build": "pnpm  next build",
    "start": "pnpm  next start",
    "clean": "git clean -xdf .cache .next node_modules",
    "check:lint": "ultracite fix",
    "check:types": "pnpm  next typegen && tsc --noEmit",
    "check:all": "pnpm check:lint && pnpm check:types",
    "prepare": "husky"
  },
  "dependencies": {
    "next": "16.2.2",
    "react": "19.2.4",
    "react-dom": "19.2.4"
  },
  "devDependencies": {
    "@biomejs/biome": "2.4.10",
    "@commitlint/cli": "^20.5.0",
    "@commitlint/config-conventional": "^20.5.0",
    "@tailwindcss/postcss": "^4.2.0",
    "@types/node": "^22.19.0",
    "@types/react": "^19.2.3",
    "@types/react-dom": "^19.2.3",
    "babel-plugin-react-compiler": "1.0.0",
    "husky": "^9.1.7",
    "tailwindcss": "^4.2.0",
    "tsx": "^4.21.0",
    "typescript": "^5.9.3",
    "ultracite": "7.4.3"
  },
  "commitlint": {
    "extends": [
      "@commitlint/config-conventional"
    ]
  },
  "engines": {
    "node": ">=22.x",
    "pnpm": ">=10.x"
  },
  "packageManager": "pnpm@10.33.0"
}
