// ==============================
// CATALOG ENUMS
// ==============================

enum ProductType {
  goods
  services
}

enum ProductStatus {
  draft
  active
  inactive
  archived
  discontinued
}

// ==============================
// PRODUCTS
// ==============================

model Product {
  id   String @id @default(cuid())
  name String
  slug String @unique

  type ProductType @default(goods)

  status ProductStatus @default(draft)

  basePrice Decimal @default(0) @db.Decimal(19, 8)

  currencyCode String  @default("IDR")
  exchangeRate Decimal @default(1) @db.Decimal(19, 8)

  unit      String
  weight    Decimal? @default(0) @db.Decimal(19, 8)
  dimension Json?

  createdAt DateTime  @default(now())
  updatedAt DateTime  @updatedAt
  deletedAt DateTime?

  createdBy String?
  updatedBy String?
  deletedBy String?

  variants         Variant[]
  productMedias    ProductMedia[]
  categoryProducts CategoryProduct[]
  orderItems       OrderItem[]

  @@map("products")
}

// ==============================
// VARIANTS
// ==============================

model Variant {
  id        String @id @default(cuid())
  productId String

  label String
  sku   String

  price String

  unit  String
  stock Int    @default(0)

  enabled  Boolean @default(true)
  position Int     @default(0)

  weight    Decimal? @default(0) @db.Decimal(19, 8)
  dimension Json?

  createdAt DateTime  @default(now())
  updatedAt DateTime  @updatedAt
  deletedAt DateTime?

  createdBy String?
  updatedBy String?
  deletedBy String?

  product Product @relation(fields: [productId], references: [id], onDelete: Cascade)

  prices         Price[]
  designAreas    DesignArea[]
  materials      Material[]
  variantMedias  VariantMedia[]
  orderItems     OrderItem[]
  stockProducts  StockProduct[]
  stockMovements StockMovement[]

  @@map("variants")
}

// ==============================
// PRICES
// ==============================

model Price {
  id        String @id @default(cuid())
  variantId String

  variant Variant @relation(fields: [variantId], references: [id], onDelete: Cascade)

  @@map("prices")
}

// ==============================
// DESIGN AREA
// ==============================

model DesignArea {
  id        String @id @default(cuid())
  variantId String

  variant Variant @relation(fields: [variantId], references: [id], onDelete: Cascade)

  @@map("design_areas")
}
