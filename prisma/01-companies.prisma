// ==============================
// COMPANY ENUMS
// ==============================

enum OrganizationStatus {
  pending // not verified
  active // verified
  inactive // by owner
  banned // by super_admin
  deleted
}

enum InvitationStatus {
  pending
  accepted
  rejected
  canceled
}

// ==============================
// BETTER-AUTH ORGANIZATIONS
// ==============================

model Organization {
  id   String  @id @default(cuid())
  name String
  slug String  @unique
  logo String?

  metadata Json?

  // additionals
  banner   String?
  status   OrganizationStatus @default(pending)
  settings Json?

  createdAt DateTime  @default(now())
  updatedAt DateTime  @updatedAt
  deletedAt DateTime?

  createdBy String?
  updatedBy String?
  deletedBy String?

  organizationRoles OrganizationRole[]
  members           Member[]
  invitations       Invitation[]
  customers         Customer[]
  stores            Store[]
  medias            Media[]
  suppliers         Supplier[]
  profiles          Profile[]
  webhooks          Webhook[]
  categories        Category[]
  posTerminals      PosTerminal[]
  posSessions       PosSession[]
  channels          Channel[]
  orders            Order[]
  payments          Payment[]
  refunds           Refund[]
  stockProducts     StockProduct[]
  stockMaterials    StockMaterial[]
  stockMovements    StockMovement[]

  @@index([status])
  @@map("organizations")
}

// ==============================
// BETTER-AUTH ORGANIZATION ROLES
// ==============================

model OrganizationRole {
  id             String @id @default(cuid())
  organizationId String
  role           String
  permission     Json
  metadata       Json?

  // additionals
  isSystem Boolean @default(false) // system_org_role
  enabled  Boolean @default(true)

  // timestamps
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  organization Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)

  @@unique([organizationId, role])
  @@index([isSystem, enabled])
  @@map("org_roles")
}

// ==============================
// BETTER-AUTH MEMBERS
// ==============================

model Member {
  id             String @id @default(cuid())
  organizationId String
  userId         String
  role           String @default("member")

  // additionals
  enabled  Boolean @default(true)
  metadata Json?

  // timestamps
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  organization Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  user         User         @relation(fields: [userId], references: [id], onDelete: Cascade)

  staffs Staff[]

  @@unique([organizationId, userId])
  @@index([role])
  @@index([enabled])
  @@map("members")
}

// ==============================
// BETTER-AUTH INVITATIONS
// ==============================

model Invitation {
  id             String @id @default(cuid())
  organizationId String
  inviterId      String

  // targets
  email     String
  role      String           @default("member")
  status    InvitationStatus @default(pending)
  expiresAt DateTime

  // additionals
  metadata Json?

  // timestamps
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  organization Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  inviter      User         @relation(fields: [inviterId], references: [id], onDelete: Cascade)

  @@unique([organizationId, email])
  @@index([inviterId])
  @@index([status])
  @@map("invitations")
}

// ==============================
// CUSTOMERS
// ==============================

model Customer {
  id             String  @id @default(cuid())
  organizationId String
  userId         String? // online customer
  name           String
  slug           String

  enabled  Boolean @default(true)
  metadata Json?

  createdAt DateTime  @default(now())
  updatedAt DateTime  @updatedAt
  deletedAt DateTime?

  createdBy String?
  updatedBy String?
  deletedBy String?

  organization Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  user         User?        @relation(fields: [userId], references: [id], onDelete: SetNull)

  profiles Profile[]
  orders   Order[]

  @@unique([organizationId, slug])
  @@index([userId])
  @@map("customers")
}

// ==============================
// STAFFS
// ==============================

model Staff {
  id       String  @id @default(uuid())
  memberId String? // online staff
  name     String
  slug     String

  enabled  Boolean @default(true)
  metadata Json?

  createdAt DateTime  @default(now())
  updatedAt DateTime  @updatedAt
  deletedAt DateTime?

  createdBy String?
  updatedBy String?
  deletedBy String?

  member Member? @relation(fields: [memberId], references: [id], onDelete: SetNull)

  profiles Profile[]

  @@unique([memberId, slug])
  @@map("staffs")
}

// ==============================
// SUPPLIERS
// ==============================

model Supplier {
  id             String @id @default(uuid())
  organizationId String
  name           String
  slug           String

  enabled  Boolean @default(true)
  metadata Json?

  createdAt DateTime  @default(now())
  updatedAt DateTime  @updatedAt
  deletedAt DateTime?

  createdBy String?
  updatedBy String?
  deletedBy String?

  organization Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)

  profiles Profile[]

  @@unique([organizationId, slug])
  @@map("suppliers")
}

// ==============================
// STOCK PRODUCTS
// ==============================

model StockProduct {
  id             String @id @default(uuid())
  organizationId String
  variantId      String

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  organization Organization @relation(fields: [organizationId], references: [id])
  variant      Variant      @relation(fields: [variantId], references: [id], onDelete: Cascade)
}

// ==============================
// STOCK MATERIALS
// ==============================

model StockMaterial {
  id             String @id @default(uuid())
  organizationId String
  materialId     String

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  organization Organization @relation(fields: [organizationId], references: [id])
  material     Material     @relation(fields: [materialId], references: [id], onDelete: Cascade)
}
