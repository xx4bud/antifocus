{
  "name": "@antifocus/auth",
  "type": "module",
  "private": true,
  "scripts": {
    "build": "tsc",
    "clean": "git clean -xdf .cache .turbo dist node_modules",
    "check:lint": "biome check --write --unsafe .",
    "check:types": "tsc --noEmit",
    "check:all": "pnpm check:lint && pnpm check:types"
  },
  "dependencies": {
    "@antifocus/config": "workspace:*",
    "@antifocus/db": "workspace:*",
    "@antifocus/env": "workspace:*",
    "@arcjet/ip": "1.0.0-beta.15",
    "@arcjet/next": "1.0.0-beta.15",
    "@better-auth/expo": "catalog:",
    "@casl/ability": "^6.7.3",
    "@node-rs/argon2": "^2.0.2",
    "@ucast/core": "^1.10.2",
    "better-auth": "catalog:"
  },
  "devDependencies": {
    "@antifocus/tsconfig": "workspace:*",
    "@better-auth/cli": "catalog:",
    "@types/node": "catalog:",
    "typescript": "catalog:"
  },
  "exports": {
    ".": {
      "default": "./src/index.ts",
      "types": "./dist/index.d.ts"
    },
    "./*": {
      "default": "./src/*.ts",
      "types": "./dist/*.d.ts"
    }
  }
}
