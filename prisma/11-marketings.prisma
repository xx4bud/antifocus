enum BannerPlacement {
  hero
}

model Banner {
  id          String @id @default(cuid())
  title       String
  description String
  url         String

  placement BannerPlacement
  enabled   Boolean         @default(true)
  position  Int?
  metadata  Json?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  bannerMedias BannerMedia[]

  @@index([enabled])
  @@map("banners")
}
