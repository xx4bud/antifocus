{
  "name": "@antifocus/cli",
  "type": "module",
  "private": true,
  "scripts": {
    "build": "tsc",
    "clean": "git clean -xdf .cache .turbo dist node_modules",
    "check:lint": "biome check --write --unsafe .",
    "check:types": "tsc --noEmit",
    "check:all": "pnpm check:lint && pnpm check:types",
    "gen:schemas": "tsx src/generate-schemas.ts",
    "gen:schemas:all": "tsx src/generate-schemas.ts --all"
  },
  "devDependencies": {
    "@antifocus/tsconfig": "workspace:*",
    "@types/node": "catalog:",
    "tsx": "^4.21.0",
    "typescript": "catalog:"
  }
}
