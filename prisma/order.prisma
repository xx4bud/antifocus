// ==============================
// Orders
// ==============================

model Order {
    id             String  @id @default(cuid())
    organizationId String  @map("organization_id")
    branchId       String? @map("branch_id")
    customerId     String  @map("customer_id")

    orderNumber String      @map("order_number")
    status      OrderStatus @default(pending)

    currencyCode   CurrencyCode @default(IDR) @map("currency_code")
    subTotal       BigInt       @default(0) @map("sub_total")
    shippingAmount BigInt       @default(0) @map("shipping_amount")
    taxAmount      BigInt       @default(0) @map("tax_amount")
    discountAmount BigInt       @default(0) @map("discount_amount")
    totalAmount    BigInt       @default(0) @map("total_amount")

    shippingAddress Json @map("shipping_address") @db.JsonB
    billingAddress  Json @map("billing_address") @db.JsonB

    createdAt DateTime  @default(now()) @map("created_at") @db.Timestamptz(3)
    updatedAt DateTime  @updatedAt @map("updated_at") @db.Timestamptz(3)
    deletedAt DateTime? @map("deleted_at") @db.Timestamptz(3)

    organization Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)
    branch       Branch?      @relation(fields: [branchId], references: [id], onDelete: SetNull)
    customer     Customer     @relation(fields: [customerId], references: [id], onDelete: Restrict)

    items            OrderItem[]
    invoices         Invoice[]
    fulfillments     Fulfillment[]
    productionOrders ProductionOrder[]

    @@unique([organizationId, orderNumber])
    @@index([customerId])
    @@index([branchId])
    @@index([status])
    @@map("orders")
}

model OrderItem {
    id        String @id @default(cuid())
    orderId   String @map("order_id")
    variantId String @map("variant_id")

    productName String @map("product_name")
    variantName String @map("variant_name")
    sku         String?

    currencyCode  CurrencyCode @default(IDR) @map("currency_code")
    quantity      Int          @default(0)
    unitPrice     BigInt       @default(0) @map("unit_price")
    taxPrice      BigInt       @default(0) @map("tax_price")
    discountPrice BigInt       @default(0) @map("discount_price")
    totalPrice    BigInt       @default(0) @map("total_price")

    createdAt DateTime  @default(now()) @map("created_at") @db.Timestamptz(3)
    updatedAt DateTime  @updatedAt @map("updated_at") @db.Timestamptz(3)
    deletedAt DateTime? @map("deleted_at") @db.Timestamptz(3)

    order                Order                 @relation(fields: [orderId], references: [id], onDelete: Cascade)
    variant              Variant?              @relation(fields: [variantId], references: [id], onDelete: Restrict)
    orderItemDesigns     OrderItemDesign[]
    fulfillmentItems     FulfillmentItem[]
    productionOrderItems ProductionOrderItem[]
    invoiceItems         InvoiceItem[]

    @@index([orderId])
    @@index([variantId])
    @@map("order_items")
}

model OrderItemDesign {
    id          String @id @default(cuid())
    orderItemId String @map("order_item_id")
    areaId      String @map("area_id")
    fileId      String @map("file_id")

    areaName   String  @map("area_name")
    areaWidth  Decimal @map("area_width")
    areaHeight Decimal @map("area_height")

    metadata Json? @db.JsonB

    createdAt DateTime @default(now()) @map("created_at") @db.Timestamptz(3)

    orderItem OrderItem  @relation(fields: [orderItemId], references: [id], onDelete: Cascade)
    area      DesignArea @relation(fields: [areaId], references: [id], onDelete: Restrict)
    file      File       @relation(fields: [fileId], references: [id], onDelete: Restrict)

    @@unique([orderItemId, areaId])
    @@map("order_item_designs")
}
