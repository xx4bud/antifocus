// ==============================
// BETTER-AUTH ORGANIZATIONS
// ==============================

enum SystemOrgRole {
  member
  admin // per company
  owner
}

enum OrganizationStatus {
  pending // not verified
  active // verified
  inactive // by user
  deleted // by user
}

enum InvitationStatus {
  pending
  accepted
  rejected
  canceled
}

enum StoreStatus {
  open
  vacation
  closed
  maintenance
}

enum StoreType {
  retail
  warehouse
  office
}

// ==============================
// BETTER-AUTH ORGANIZATIONS
// ==============================

model Organization {
  id       String  @id @default(cuid())
  name     String
  slug     String  @unique
  logo     String?
  metadata Json?

  // additionals
  status OrganizationStatus @default(pending)
  banned Boolean            @default(false)

  // timestamps
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  // soft delete
  deletedAt DateTime?

  settings          Setting[]
  organizationRoles OrganizationRole[]
  members           Member[]
  invitations       Invitation[]
  stores            Store[]
  customers         Customer[]
  vendors           Vendor[]
  profiles          Profile[]
  addresses         Address[]
  socials           Social[]
  bankAccounts      BankAccount[]
  units             Unit[]
  categories        Category[]
  attributes        Attribute[]
  products          Product[]
  variants          Variant[]
  values            Value[]
  collections       Collection[]
  tags              Tag[]
  medias            Media[]
  banners           Banner[]
  carts             Cart[]
  saleOrders        SaleOrder[]
  purchaseOrders    PurchaseOrder[]
  accountMoves      AccountMove[]
  payments          Payment[]
  stockLocations    StockLocation[]
  stockPickings     StockPicking[]
  stockMoves        StockMove[]
  priceLists        PriceList[]
  stockStores       StockStore[]

  // Manufacturing
  billOfMaterials     BillOfMaterial[]
  manufacturingOrders ManufacturingOrder[]

  // Discounts
  coupons       Coupon[]
  discountRules DiscountRule[]

  // Returns
  returnOrders ReturnOrder[]

  // Shipping
  shippingMethods ShippingMethod[]
  shipments       Shipment[]

  // Accounting (Chart of Accounts)
  accounts ChartOfAccount[]

  // Communications
  notifications Notification[]
  activities    Activity[]

  // HR
  departments Department[]
  employees   Employee[]

  // CRM
  leadStages LeadStage[]
  leads      Lead[]

  // Reviews
  productReviews ProductReview[]

  // Taxes
  fiscalPositions FiscalPosition[]

  // Helpdesk
  ticketStages TicketStage[]
  ticketTags   TicketTag[]
  tickets      Ticket[]

  // Quality
  qualityPoints QualityPoint[]
  qualityChecks QualityCheck[]
  qualityAlerts QualityAlert[]

  // Projects
  projectStages   ProjectStage[]
  projects        Project[]
  projectTaskTags ProjectTaskTag[]
  projectTasks    ProjectTask[]
  timesheets      Timesheet[]

  // POS
  posSessions PosSession[]
  posOrders   PosOrder[]

  // Marketplace
  marketplaces Marketplace[]

  // Messaging
  messageChannels MessageChannel[]
  messageLogs     MessageLog[]

  // Website
  webMenus  WebMenu[]
  webPages  WebPage[]
  blogPosts BlogPost[]

  // Email Marketing
  subscriberLists SubscriberList[]
  emailTemplates  EmailTemplate[]
  emailCampaigns  EmailCampaign[]

  // Expenses
  expenseReports ExpenseReport[]

  // Leaves
  leaveTypes       LeaveType[]
  leaveAllocations LeaveAllocation[]
  leaveRequests    LeaveRequest[]

  // Payroll
  salaryRules SalaryRule[]
  payslipRuns PayslipRun[]
  payslips    Payslip[]

  // Approvals
  approvalCategories ApprovalCategory[]
  approvalRequests   ApprovalRequest[]

  // Documents
  documentFolders DocumentFolder[]
  documentRecords DocumentRecord[]
  documentTags    DocumentTag[]

  // Subscriptions
  subscriptions Subscription[]

  // Surveys
  surveys Survey[]

  // Design Assets (POD)
  designTemplates DesignTemplate[]
  designAssets    DesignAsset[]
  mockupPresets   MockupPreset[]

  // Maintenance
  equipmentCategories  EquipmentCategory[]
  equipment            Equipment[]
  maintenanceRequests  MaintenanceRequest[]
  maintenanceSchedules MaintenanceSchedule[]

  // Frontdesk
  visitPurposes     VisitPurpose[]
  frontdeskStations FrontdeskStation[]
  visitors          Visitor[]

  // Loyalty
  loyaltyPrograms LoyaltyProgram[]

  // Fleet
  vehicles Vehicle[]

  // Recruitment
  jobPositions    JobPosition[]
  interviewStages InterviewStage[]

  // Knowledge Base
  knowledgeCategories KnowledgeCategory[]
  knowledgeArticles   KnowledgeArticle[]
  integrations        Integration[]
  webhooks            Webhook[]
  automationRules     AutomationRule[]
  scheduledActions    ScheduledAction[]
  actionLogs          ActionLog[]
  sequences           Sequence[]
  workflowTemplates   WorkflowTemplate[]

  // Reports
  reportTemplates ReportTemplate[]
  savedReports    SavedReport[]
  reportSchedules ReportSchedule[]

  // Discussions
  channels  Channel[]
  followers Follower[]
  notes     RecordNote[]

  // Data Management
  dataExportJobs  DataExportJob[]
  dataImportJobs  DataImportJob[]
  databaseBackups DatabaseBackup[]

  @@index([status, banned])
  @@map("organizations")
}

// ==============================
// BETTER-AUTH ORGANIZATION ROLES
// ==============================

model OrganizationRole {
  id             String @id @default(cuid())
  organizationId String
  role           String
  permission     Json // action.entity
  metadata       Json?

  // additionals
  system   Boolean @default(false) // system_org_role
  enabled  Boolean @default(true)
  position Int?

  // timestamps
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  organization Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)

  @@unique([organizationId, role])
  @@index([system, enabled])
  @@map("org_roles")
}

// ==============================
// BETTER-AUTH MEMBERS
// ==============================

model Member {
  id             String @id @default(cuid())
  organizationId String
  userId         String
  role           String @default("member") // org_roles

  // additionals
  enabled  Boolean @default(true)
  metadata Json?

  // timestamps
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  organization Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  user         User         @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([organizationId, userId])
  @@index([enabled])
  @@map("members")
}

// ==============================
// BETTER-AUTH INVITATIONS
// ==============================

model Invitation {
  id             String @id @default(cuid())
  organizationId String
  inviterId      String

  // targets
  email     String
  role      String           @default("member")
  status    InvitationStatus @default(pending)
  expiresAt DateTime

  // additionals
  metadata Json?

  // timestamps
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  organization Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  inviter      User         @relation(fields: [inviterId], references: [id], onDelete: Cascade)

  @@unique([organizationId, email])
  @@index([inviterId])
  @@index([status])
  @@map("invitations")
}

// ==============================
// CUSTOMERS
// ==============================

model Customer {
  id             String  @id @default(cuid())
  organizationId String
  userId         String? // online customer
  image          String?
  cover          String?

  enabled  Boolean  @default(true)
  tags     String[]
  metadata Json?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  organization Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  user         User?        @relation(fields: [userId], references: [id], onDelete: SetNull)

  profiles     Profile[]
  saleOrders   SaleOrder[]
  returnOrders ReturnOrder[]

  // CRM
  leads Lead[]

  // Reviews
  productReviews ProductReview[] @relation("CustomerReviews")
  subscriptions  Subscription[]
  tickets        Ticket[]
  posOrders      PosOrder[]
  projects       Project[]

  // Loyalty
  loyaltyCards LoyaltyCard[]

  // Design Assets
  designAssets DesignAsset[]

  @@unique([organizationId, userId])
  @@index([enabled])
  @@map("customers")
}

// ==============================
// VENDORS
// ==============================

model Vendor {
  id             String  @id @default(cuid())
  organizationId String
  userId         String? // vendor person
  image          String?
  cover          String?

  enabled  Boolean  @default(true)
  tags     String[]
  metadata Json?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  organization Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  user         User?        @relation(fields: [userId], references: [id], onDelete: SetNull)

  profiles       Profile[]
  purchaseOrders PurchaseOrder[]

  @@unique([organizationId, userId])
  @@index([enabled])
  @@map("vendors")
}
